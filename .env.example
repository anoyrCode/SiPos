# ====================================================================
# SIPOS — Environment Variables (TEMPLATE)
# Salin file ini menjadi `.env.local`, lalu isi nilainya.
# JANGAN commit `.env.local` (sudah di-gitignore).
# ====================================================================

# --- Supabase (frontend Next.js) ---------------------------------
# Ambil dari: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Service role key — HANYA dipakai di server (admin API, generate akun wali).
# JANGAN pernah diekspos ke client / prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Database (PostgreSQL bersama Supabase & Directus) ------------
# Untuk Supabase Cloud, ambil connection string dari:
# Project Settings > Database > Connection string
DB_HOST=db.YOUR-PROJECT-ref.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USER=postgres
DB_PASSWORD=YOUR-DB-PASSWORD

# --- Directus (admin/CMS master data, lihat docker-compose.yml) ---
DIRECTUS_KEY=replace-with-random-uuid
DIRECTUS_SECRET=replace-with-random-secret
DIRECTUS_ADMIN_EMAIL=admin@sipos.local
DIRECTUS_ADMIN_PASSWORD=change-me
DIRECTUS_PUBLIC_URL=http://localhost:8055
